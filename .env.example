# StatPulse — configuração (copie para .env e preencha)
APP_NAME=StatPulse
LOG_LEVEL=INFO

# SQLite (MVP). PostgreSQL no futuro.
DATABASE_URL=sqlite:///./data/statpulse.db

# Telegram (Fase 2)
TELEGRAM_BOT_TOKEN=

# API-Football (RapidAPI) — Fase 3 (coleta de dados)
API_FOOTBALL_KEY=

# Scheduler (Fase 3+)
POLL_INTERVAL_SECONDS=60
